<Window x:Class="OneClickInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eikon Imaging Software Installer" Height="500" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FF2D2D30" FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1BA1E2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF68217A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7B2D8E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF5C1B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF3F3F46" Padding="20">
            <StackPanel>
                <TextBlock Text="Eikon Imaging Software Installer" 
                          FontSize="24" FontWeight="Bold" 
                          Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="One-click installation of essential software packages" 
                          FontSize="14" Foreground="#FFCCCCCC" 
                          HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Installation Status -->
                <Border Background="#FF3F3F46" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="StatusLabel" Text="Ready to install software packages" 
                                  FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                        
                        <!-- Overall Progress -->
                        <TextBlock Text="Overall Progress:" FontSize="12" Foreground="#FFCCCCCC" Margin="0,0,0,5"/>
                        <Grid>
                            <ProgressBar x:Name="OverallProgress" Height="25" Background="#FF404040" 
                                        Foreground="#FF007ACC" BorderThickness="0"/>
                            <TextBlock x:Name="OverallProgressText" Text="0%" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      FontWeight="SemiBold" Foreground="White"/>
                        </Grid>
                        
                        <!-- Current Item Progress -->
                        <TextBlock x:Name="CurrentItemLabel" Text="" FontSize="12" 
                                  Foreground="#FFCCCCCC" Margin="0,10,0,5"/>
                        <Grid x:Name="CurrentProgressGrid" Visibility="Collapsed">
                            <ProgressBar x:Name="CurrentProgress" Height="20" Background="#FF404040" 
                                        Foreground="#FF00CC00" BorderThickness="0"/>
                            <TextBlock x:Name="CurrentProgressText" Text="" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Software List -->
                <Border Background="#FF3F3F46" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Software to be installed:" FontSize="14" FontWeight="SemiBold" 
                                  Foreground="White" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="SoftwareList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="●" FontSize="12" 
                                                  Foreground="{Binding StatusColor}" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" 
                                                  Foreground="#FFCCCCCC"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11" 
                                                  Foreground="{Binding StatusColor}" FontStyle="Italic"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Installation Log -->
                <Border Background="#FF3F3F46" CornerRadius="6" Padding="15" Margin="0,15,0,0" 
                        x:Name="LogPanel" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Installation Log:" FontSize="14" FontWeight="SemiBold" 
                                  Foreground="White" Margin="0,0,0,10"/>
                        <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogTextBlock" FontSize="11" Foreground="#FFCCCCCC" 
                                      FontFamily="Consolas" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Time Information -->
        <Border Grid.Row="2" Background="#FF3F3F46" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TimeElapsedLabel" Grid.Column="0" Text="Time Elapsed: 00:00:00" 
                          FontSize="12" Foreground="#FFCCCCCC"/>
                <TextBlock x:Name="TimeRemainingLabel" Grid.Column="1" Text="Estimated Time Remaining: --:--:--" 
                          FontSize="12" Foreground="#FFCCCCCC" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Border Grid.Row="3" Background="#FF383838" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ExitButton" Content="Exit" 
                       Style="{StaticResource ExitButton}" Width="100" 
                       Click="ExitButton_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>