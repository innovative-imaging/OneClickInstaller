<?xml version="1.0" encoding="UTF-8"?>

<!--
  GVP-Pro MSI Installer
  Version: 1.0.2
  Installs to: D:\GVP-Pro\App\ (configurable via INSTALLDIR property)
  
  UpgradeCode is FIXED across all versions — this enables clean upgrades.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="GVP-Pro Medical Imaging System"
    Manufacturer="Eikon"
    Version="1.0.2"
    UpgradeCode="7B1E2F3A-4C5D-6E7F-8A9B-0C1D2E3F4A5B"
    Scope="perMachine">

    <!-- Upgrade logic: remove any older version before installing -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of GVP-Pro is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Set default install directory to D:\GVP-Pro\App -->
    <Property Id="INSTALLDIR" Value="D:\GVP-Pro\App\" />
    <SetDirectory Id="INSTALLDIR" Value="[INSTALLDIR]" Sequence="first" />

    <!-- Directory structure using custom INSTALLDIR -->
    <StandardDirectory Id="TARGETDIR">
      <Directory Id="INSTALLDIR" Name="App">

        <!-- Main Application -->
        <Component Id="MainApp" Guid="A1B2C3D4-E5F6-7890-A1B2-C3D4E5F67890">
          <File Source="..\publish\GVPPro.exe" />
          <File Source="..\publish\GVPPro.dll" />
          <File Source="..\publish\GVPPro.deps.json" />
          <File Source="..\publish\GVPPro.runtimeconfig.json" />
        </Component>

        <!-- Image Acquisition Service -->
        <Component Id="AcquisitionService" Guid="B2C3D4E5-F6A7-8901-B2C3-D4E5F6A78901">
          <File Source="..\publish\GVPPro.ImageAcquisitionService.exe" />
          <File Source="..\publish\GVPPro.ImageAcquisitionService.dll" />
          <File Source="..\publish\GVPPro.ImageAcquisitionService.deps.json" />
          <File Source="..\publish\GVPPro.ImageAcquisitionService.runtimeconfig.json" />
        </Component>

        <!-- Image Processing Service -->
        <Component Id="ProcessingService" Guid="C3D4E5F6-A7B8-9012-C3D4-E5F6A7B89012">
          <File Source="..\publish\GVPPro.ImageProcessingService.exe" />
          <File Source="..\publish\GVPPro.ImageProcessingService.dll" />
          <File Source="..\publish\GVPPro.ImageProcessingService.deps.json" />
          <File Source="..\publish\GVPPro.ImageProcessingService.runtimeconfig.json" />
        </Component>

        <!-- Startup Scripts -->
        <Component Id="StartupScripts" Guid="D4E5F6A7-B8C9-0123-D4E5-F6A7B8C90123">
          <File Id="KioskLauncher" Source="..\..\OS_ClosedLoop\VM_Files\GVP-Pro\App\KioskLauncher.vbs" />
          <File Id="StartGVP" Source="..\..\OS_ClosedLoop\VM_Files\GVP-Pro\App\StartGVPProcesses.bat" />
          <File Id="KillGVP" Source="..\..\OS_ClosedLoop\VM_Files\GVP-Pro\App\KillGVPProcesses.bat" />
          <File Id="RunImgProc" Source="..\..\OS_ClosedLoop\VM_Files\GVP-Pro\App\run_imageprocessing.bat" />
        </Component>

        <!-- Service Tools (deployed alongside app for easy access) -->
        <Component Id="ServiceTools" Guid="E5F6A7B8-C9D0-1234-E5F6-A7B8C9D01234">
          <File Id="ServiceModeBat" Source="..\..\OS_ClosedLoop\ServiceTools\ServiceMode.bat" />
          <File Id="ResealKioskBat" Source="..\..\OS_ClosedLoop\ServiceTools\ResealKiosk.bat" />
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- Feature containing all components -->
    <Feature Id="Complete" Title="GVP-Pro Complete" Level="1">
      <ComponentRef Id="MainApp" />
      <ComponentRef Id="AcquisitionService" />
      <ComponentRef Id="ProcessingService" />
      <ComponentRef Id="StartupScripts" />
      <ComponentRef Id="ServiceTools" />
    </Feature>

    <!-- Custom Action: Kill running GVP processes before file replacement -->
    <CustomAction Id="KillProcesses"
                  Directory="INSTALLDIR"
                  ExeCommand='cmd.exe /c "taskkill /F /IM GVPPro.exe 2>nul &amp; taskkill /F /IM GVPPro.ImageAcquisitionService.exe 2>nul &amp; taskkill /F /IM GVPPro.ImageProcessingService.exe 2>nul &amp; timeout /t 2 /nobreak >nul"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="KillProcesses" Before="InstallFiles" Condition="Installed OR UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

  </Package>

</Wix>
